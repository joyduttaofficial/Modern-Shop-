rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == role;
    }
    
    function isAdmin() {
      return isSignedIn() && (hasRole('admin') || request.auth.token.email == "joydutta398878@gmail.com");
    }
    
    function isAccountant() {
      return hasRole('accountant') || isAdmin();
    }
    
    function isSales() {
      return hasRole('sales') || isAccountant();
    }

    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }

    // User Profiles
    match /users/{userId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId && (!incoming().keys().hasAny(['role']) || incoming().role == existing().role));
      allow delete: if isAdmin() || (isSignedIn() && existing().email == request.auth.token.email);
    }

    // Role Permissions
    match /roles/{roleId} {
      allow read, list: if isSignedIn();
      allow write, create, update, delete: if isAdmin();
    }

    // Transaction Validation
    function isValidTransaction(data) {
      return data.keys().hasAll(['date', 'type', 'category', 'amount', 'paymentMethod'])
        && data.type in ['income', 'expense']
        && data.amount is number
        && data.date is string;
    }

    match /transactions/{transactionId} {
      allow read, list: if isSales();
      allow create: if isSales() && isValidTransaction(incoming());
      allow update: if isAccountant() && isValidTransaction(incoming());
      allow delete: if isAdmin();
    }

    // Employee Validation
    function isValidEmployee(data) {
      return data.keys().hasAll(['name', 'role', 'salary', 'status', 'joinedDate'])
        && data.name is string && data.name.size() > 0
        && data.role is string
        && data.salary is number
        && data.status in ['active', 'inactive']
        && data.joinedDate is string;
    }

    match /employees/{employeeId} {
      allow read, list: if isSales();
      allow create, update: if isAccountant() && isValidEmployee(incoming());
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read, list: if isSales();
      allow create, update, delete: if isAccountant();
    }

    match /banks/{bankId} {
      allow read, list: if isSales();
      allow create, update, delete: if isAccountant();
    }

    // Attendance Validation
    function isValidAttendance(data) {
      return data.keys().hasAll(['date', 'employeeId', 'status'])
        && data.date is string
        && data.employeeId is string
        && data.status in ['present', 'absent', 'late', 'half-day', 'leave', 'holiday'];
    }

    match /attendance/{attendanceId} {
      allow read, list: if isSales();
      allow create, update: if isAccountant() && isValidAttendance(incoming());
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isSales();
      allow write: if isAccountant();
    }

    // Supplier Validation
    function isValidSupplier(data) {
      return data.keys().hasAll(['name', 'code', 'country', 'status'])
        && data.name is string && data.name.size() > 0
        && data.code is string
        && data.country is string
        && data.status in ['active', 'inactive'];
    }

    // SupplierTransaction Validation
    function isValidSupplierTransaction(data) {
      return data.keys().hasAll(['supplierId', 'date', 'type', 'totalAmount'])
        && data.supplierId is string
        && data.date is string
        && data.type in ['purchase', 'return', 'payment']
        && data.totalAmount is number;
    }

    // Purchase Validation
    function isValidPurchase(data) {
      return data.keys().hasAll(['supplierId', 'supplierName', 'date', 'refNo', 'totalAmount', 'paidAmount', 'dueAmount', 'paymentMethod', 'createdAt'])
        && data.supplierId is string
        && data.supplierName is string
        && data.date is string
        && data.refNo is string
        && data.totalAmount is number
        && data.paidAmount is number
        && data.dueAmount is number
        && data.paymentMethod is string
        && data.createdAt is string;
    }

    match /suppliers/{supplierId} {
      allow read, list: if isSales();
      allow create, update: if isAccountant() && isValidSupplier(incoming());
      allow delete: if isAdmin();
    }

    match /supplierTransactions/{transactionId} {
      allow read, list: if isSales();
      allow create, update: if isAccountant() && isValidSupplierTransaction(incoming());
      allow delete: if isAdmin();
    }

    match /purchases/{purchaseId} {
      allow read, list: if isSales();
      allow create: if isAccountant() && isValidPurchase(incoming());
      allow delete: if isAdmin();
    }
  }
}
