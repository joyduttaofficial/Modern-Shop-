rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if a user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // 1. Allow read, list on all collections for any authenticated user
    // This allows real-time stats and dashboard list views to work flawlessly for all roles.
    match /{document=**} {
      allow read, list: if isSignedIn();
    }

    // 2. Allow write (create, update, delete) on all collections for authenticated users to ensure trouble-free execution of workflows.
    match /users/{userId} {
      allow write: if isSignedIn();
    }

    match /roles/{roleId} {
      allow write: if isSignedIn();
    }

    match /transactions/{transactionId} {
      allow write: if isSignedIn();
    }

    match /employees/{employeeId} {
      allow write: if isSignedIn();
    }

    match /categories/{categoryId} {
      allow write: if isSignedIn();
    }

    match /banks/{bankId} {
      allow write: if isSignedIn();
    }

    match /attendance/{attendanceId} {
      allow write: if isSignedIn();
    }

    match /settings/company {
      allow read: if true;
    }

    match /test/connection {
      allow read: if true;
    }

    match /settings/{settingId} {
      allow write: if isSignedIn();
    }

    match /suppliers/{supplierId} {
      allow write: if isSignedIn();
    }

    match /supplierTransactions/{transactionId} {
      allow write: if isSignedIn();
    }

    match /purchases/{purchaseId} {
      allow write: if isSignedIn();
    }

    match /departments/{departmentId} {
      allow write: if isSignedIn();
    }
  }
}
